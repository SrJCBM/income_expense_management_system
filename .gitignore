# ==================================================
# INCOME & EXPENSE MANAGEMENT SYSTEM - .gitignore
# ==================================================
# DO NOT COMMIT: Sensitive data, dependencies, build outputs

# ============================================
# ENVIRONMENT VARIABLES (SENSITIVE DATA) ⚠️
# ============================================
.env
.env.local
.env.*.local
.env.development
.env.production
.env.*.example

# ============================================
# NODE.JS & NPM
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
pnpm-lock.yaml
yarn.lock

# ============================================
# DEPENDENCIES
# ============================================
/.pnp
.pnp.js

# ============================================
# BUILD OUTPUTS
# ============================================
build/
dist/
es/
lib/
*.tsbuildinfo
out/

# ============================================
# TESTING & COVERAGE
# ============================================
coverage/
.nyc_output/
*.lcov
.jest_cache/

# ============================================
# IDE & EDITOR
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
*.sublime-project

# ============================================
# OS FILES
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.fseventsd

# ============================================
# LOGS & TEMP
# ============================================
logs/
tmp/
temp/
*.log
lerna-debug.log*

# ============================================
# DATABASE
# ============================================
*.sqlite
*.db
*.db-journal
dump.rdb
data/

# ============================================
# BACKEND SPECIFIC
# ============================================
backend/node_modules/
backend/dist/
backend/.env
backend/.env.local
backend/coverage/
backend/logs/

# ============================================
# FRONTEND SPECIFIC
# ============================================
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local
frontend/coverage/
frontend/.parcel-cache
frontend/.cache
frontend/release/

# ============================================
# MISC
# ============================================
.cache/
.venv/
venv/
env/
ENV/
cypress-mcp/

# ============================================
# INTERNAL MARKDOWN NOTES
# ============================================
# Local assistant instructions, one-off audits, scripts and build notes
# that are not needed for a conventional public GitHub repository.
agents.md
CLAUDE.md
AUDIT_GRAPHICS_ACCESSIBILITY.md
docs/guion-video-cypress.md
frontend/BUILD_CHECKLIST.md
frontend/BUILD_QUICK_GUIDE.md
frontend/ELECTRON_BUILD.md
frontend/README_BUILD.md

# ============================================
