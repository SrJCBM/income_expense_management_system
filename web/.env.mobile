# Modo "mobile" — build para emulador Android en desarrollo.
# El emulador Android ve el localhost de la PC como 10.0.2.2.
# Para probar en un TELEFONO FISICO, cambiar temporalmente a la IP LAN
# de la PC, p. ej. VITE_API_URL=http://192.168.1.50:5000/api
VITE_API_URL=http://10.0.2.2:5000/api
VITE_API_TIMEOUT=15000
