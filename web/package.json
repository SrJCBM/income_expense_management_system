{
  "name": "financeapp-web",
  "private": true,
  "version": "1.2.0",
  "description": "FinanceApp web frontend (React + Vite) for personal income, expense, budget and report management.",
  "type": "module",
  "author": "Ricardo Lainez",
  "license": "MIT",
  "homepage": "https://github.com/Ricardo-lainez/income_expense_management_system#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ricardo-lainez/income_expense_management_system.git"
  },
  "bugs": {
    "url": "https://github.com/Ricardo-lainez/income_expense_management_system/issues"
  },
  "keywords": ["finance", "income", "expense", "budget", "reports", "react", "vite"],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "cypress": "node scripts/run-cypress.cjs open",
    "cypress:open": "node scripts/run-cypress.cjs open",
    "cypress:run": "node scripts/run-cypress.cjs run",
    "cypress:video:expenses": "node scripts/run-cypress.cjs run --headed --browser electron --spec cypress/e2e/expenses.cy.js",
    "test:e2e": "start-server-and-test \"npm run dev -- --host 127.0.0.1 --port 3000\" http://127.0.0.1:3000/index.html test:e2e:raw",
    "test:e2e:raw": "node scripts/run-cypress.cjs run",
    "test:e2e:smoke": "start-server-and-test \"npm run dev -- --host 127.0.0.1 --port 3000\" http://127.0.0.1:3000/index.html test:e2e:smoke:raw",
    "test:e2e:smoke:raw": "node scripts/run-cypress.cjs run --spec cypress/e2e/regression.cy.js",
    "test:a11y": "start-server-and-test \"npm run dev -- --host 127.0.0.1 --port 3000\" http://127.0.0.1:3000/index.html test:a11y:raw",
    "test:a11y:raw": "node scripts/run-cypress.cjs run --spec cypress/e2e/accessibility.cy.js",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest"
  },
  "dependencies": {
    "axios": "^1.5.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.15.0",
    "recharts": "^3.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "cypress": "^15.16.0",
    "cypress-axe": "^1.5.0",
    "start-server-and-test": "^2.0.13",
    "vite": "^4.4.0",
    "vitest": "^3.2.4"
  }
}
