{
  "name": "income-expense-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:frontend": "vite build",
    "build:backend": "cd ../backend && npm install --omit=dev --no-audit --no-fund",
    "build:resources": "npm run build:frontend && npm run build:backend",
    "build:dist": "powershell -ExecutionPolicy Bypass -File scripts/build-dist.ps1",
    "electron-dev": "cross-env ELECTRON=1 electron .",
    "electron": "electron .",
    "electron-build": "npm run build:dist",
    "electron-dist": "npm run build:dist",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "test:e2e": "cypress run",
    "test:a11y": "cypress run --spec 'cypress/e2e/accessibility.cy.js'"
  },
  "dependencies": {
    "axios": "^1.5.0",
    "jspdf": "^4.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.15.0",
    "recharts": "^3.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "cross-env": "^7.0.3",
    "cypress": "^13.0.0",
    "cypress-axe": "^1.5.0",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "vite": "^4.4.0"
  },
  "build": {
    "appId": "com.incomeexpense.desktop",
    "productName": "Income Expense Manager",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist/resources/backend",
        "to": "backend"
      }
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "directories": {
      "buildResources": "public",
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false,
      "certificateFile": null,
      "certificatePassword": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Income Expense Manager"
    }
  }
}
